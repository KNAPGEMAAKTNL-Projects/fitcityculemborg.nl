---
import { openingHours } from '../../data/hours';

const hoursSpec = openingHours.flatMap(({ days, times }) => {
  const [open, close] = times.split(' - ').map(t => t.trim());
  const dayMap: Record<string, string[]> = {
    'Ma - Vr': ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    'Za': ['Saturday'],
    'Zo': ['Sunday'],
  };
  const matched = dayMap[days] || [];
  return matched.map(day => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: day,
    opens: open,
    closes: close,
  }));
});

