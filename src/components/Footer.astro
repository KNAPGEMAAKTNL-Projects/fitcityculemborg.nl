---
import { footerNav, legalNav } from '../data/navigation';
import { openingHours } from '../data/hours';
---
<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Column 1: Brand (2fr) -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">[FITCITY]</a>
        <p class="footer-tagline">Gewoon een goede gym.</p>
        <address class="footer-address">
          <p>[Straatnaam + nummer]</p>
          <p>[4101 XX] Culemborg</p>
        </address>
      </div>

      <!-- Column 2: Navigation (1fr) -->
      <div class="footer-col">
        <h3 class="footer-col-heading">Navigatie</h3>
        <nav aria-label="Footer navigatie">
          <ul class="footer-links">
            {footerNav.map(item => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Column 3: Opening Hours (1fr) -->
      <div class="footer-col">
        <h3 class="footer-col-heading">Openingstijden</h3>
        <dl class="footer-hours">
          {openingHours.map(({ days, times }) => (
            <div class="footer-hours-row">
              <dt>{days}</dt>
              <dd>{times}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- Column 4: Contact (1fr) -->
      <div class="footer-col">
        <h3 class="footer-col-heading">Contact</h3>
        <ul class="footer-contact">
          <li>
            <a href="tel:0345000000" class="footer-contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              0345-000000
            </a>
          </li>
          <li>
            <a href="mailto:info@fitcityculemborg.nl" class="footer-contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              info@fitcityculemborg.nl
            </a>
          </li>
          <li>
            <a href="https://wa.me/31600000000?text=Hoi%2C%20ik%20heb%20een%20vraag%20over%20FitCity" target="_blank" rel="noopener" class="footer-contact-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Footer bottom bar -->
    <div class="footer-bottom">
      <div class="footer-legal-links">
        {legalNav.map((item, i) => (
          <>
            <a href={item.href}>{item.label}</a>
            {i < legalNav.length - 1 && <span class="footer-sep">|</span>}
          </>
        ))}
      </div>
      <p class="footer-copyright">&copy; {new Date().getFullYear()} [FitCity] Culemborg. Alle rechten voorbehouden.</p>
      <p class="footer-legal-ids">KVK: [nummer] &middot; BTW: [nummer]</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface-dark);
    padding: 3rem 0 1.5rem;
  }

  @media (min-width: 768px) {
    .site-footer { padding: 4rem 0 2rem; }
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-container { padding: 0 2rem; }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 2rem;
    }
  }

  .footer-logo {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    color: var(--color-separator);
    font-size: 0.9rem;
    font-style: italic;
    margin-bottom: 1.5rem;
  }

  .footer-address {
    font-style: normal;
  }

  .footer-address p {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .footer-col-heading {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .footer-col-heading::after { display: none; }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--color-text); }

  .footer-hours {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-hours-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .footer-hours dt {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .footer-hours dd {
    color: var(--color-text-body);
    font-size: 0.875rem;
    margin: 0;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer-contact-link:hover { color: var(--color-text); }
  .footer-contact-link svg { flex-shrink: 0; }

  /* Bottom bar */
  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .footer-legal-links {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .footer-legal-links a {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    transition: color 0.2s;
  }

  .footer-legal-links a:hover { color: var(--color-text); }

  .footer-sep {
    color: var(--color-border);
    font-size: 0.8rem;
  }

  .footer-copyright {
    color: var(--color-text-muted);
    font-size: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .footer-legal-ids {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    opacity: 0.6;
  }
</style>
