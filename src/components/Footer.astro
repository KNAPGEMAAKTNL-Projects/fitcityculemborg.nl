---
import { footerNav, legalNav } from '../data/navigation';
import { openingHours } from '../data/hours';
---
<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-grid">
      <!-- Column 1: Brand -->
      <div>
        <h3 class="footer-heading">FITCITY CULEMBORG</h3>
        <p class="footer-tagline">De meest betaalbare sportschool van Culemborg.</p>
        <div class="footer-social">
          <a href="https://www.facebook.com/p/Fitcity-Culemborg-100063646716139/" target="_blank" rel="noopener" aria-label="Facebook" class="footer-social-link">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12a10 10 0 1 0-11.563 9.875v-6.988H7.898V12h2.539V9.797c0-2.506 1.493-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.261c-1.243 0-1.63.773-1.63 1.566V12h2.773l-.443 2.887h-2.33v6.988A10.002 10.002 0 0 0 22 12Z"/></svg>
          </a>
          <a href="https://www.instagram.com/fitcityculemborg" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social-link">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4Zm0 2a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H7Zm5 3.5A3.5 3.5 0 1 1 8.5 12 3.5 3.5 0 0 1 12 8.5Zm0 2a1.5 1.5 0 1 0 1.5 1.5A1.5 1.5 0 0 0 12 10.5Zm4.75-3.75a.75.75 0 1 1-.75.75.75.75 0 0 1 .75-.75Z"/></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Opening Hours -->
      <div>
        <h3 class="footer-heading">OPENINGSTIJDEN</h3>
        <ul class="footer-hours">
          {openingHours.map(({ days, times }) => (
            <li>
              <span class="footer-hours-day">{days}</span>
              <br />
              {times}
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Links -->
      <div>
        <h3 class="footer-heading">LINKS</h3>
        <nav aria-label="Footer navigatie">
          <ul class="footer-links">
            {footerNav.map(item => (
              <li><a href={item.href}>{item.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="footer-heading">CONTACT</h3>
        <address class="footer-contact">
          <p>Houtweg 8</p>
          <p>4104 AB Culemborg</p>
          <p style="margin-top: 0.75rem;"><a href="tel:+31646872274">06-46872274</a></p>
          <p><a href="mailto:info@fitcityculemborg.nl">info@fitcityculemborg.nl</a></p>
          <p><a href="https://wa.me/31646872274?text=Hoi%2C%20ik%20heb%20een%20vraag%20over%20Fitcity" target="_blank" rel="noopener">WhatsApp</a></p>
        </address>
      </div>
    </div>

    <!-- Footer bottom bar -->
    <div class="footer-bottom">
      <div class="footer-bottom-left">
        <span>&copy; {new Date().getFullYear()} Fitcity Culemborg.</span>
        <span>Gerealiseerd door <a href="https://knapgemaakt.nl/project/maatwerk-website-voor-fitcity-culemborg/" target="_blank" rel="noopener">KNAP GEMAAKT.</a></span>
      </div>
      <div class="footer-bottom-right">
        {legalNav.map((item, i) => (
          <>
            <a href={item.href}>{item.label}</a>
            {i < legalNav.length - 1 && <span class="footer-sep">|</span>}
          </>
        ))}
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface-dark);
    border-top: 1px solid var(--color-border);
    padding: 3.5rem 0 1.5rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-container { padding: 0 2rem; }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .footer-heading::after { display: none; }

  .footer-tagline {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .footer-social {
    display: flex;
    gap: 0.75rem;
  }

  .footer-social-link {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-social-link:hover { color: var(--color-primary); }

  .footer-hours {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    list-style: none;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .footer-hours-day {
    font-weight: 600;
    color: var(--color-text);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: var(--color-primary); }

  .footer-contact {
    font-style: normal;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .footer-contact a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-contact a:hover { color: var(--color-primary); }

  /* Bottom bar */
  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-bottom-left {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.25rem 0.75rem;
  }

  .footer-bottom-right {
    display: flex;
    gap: 0.75rem;
  }

  .footer-bottom a {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .footer-bottom a:hover { color: var(--color-primary); }

  .footer-sep {
    color: var(--color-border);
  }
</style>
