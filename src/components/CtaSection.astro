---
interface Props {
  title: string;
  text: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const { title, text, primaryLabel, primaryHref, secondaryLabel, secondaryHref } = Astro.props;
---
<section class="cta-section">
  <!-- Visual Craft: CSS Dot Grid -->
  <div class="cta-dot-grid" aria-hidden="true"></div>

  <div class="cta-inner">
    <h2 class="cta-title">{title}</h2>
    <p class="cta-text">{text}</p>
    <div class="cta-buttons">
      <a href={primaryHref} class="btn-dark">{primaryLabel}</a>
      {secondaryLabel && secondaryHref && (
        <a href={secondaryHref} class="btn-outline-dark">{secondaryLabel}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: var(--color-primary);
    padding: 3rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .cta-section { padding: 5rem 2rem; }
  }

  .cta-dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(20,20,20,0.08) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2rem);
    text-transform: uppercase;
    color: var(--color-bg);
    margin-bottom: 1rem;
  }

  .cta-title::after { display: none; }

  .cta-text {
    color: var(--color-bg);
    opacity: 0.8;
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .cta-buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  .btn-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--color-bg);
    color: var(--color-primary);
    padding: 1rem 2.5rem;
    border: none;
    min-height: 44px;
    transition: opacity 0.2s;
  }

  .btn-dark:hover { opacity: 0.9; }

  .btn-outline-dark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: transparent;
    color: var(--color-bg);
    padding: 1rem 2.5rem;
    border: 2px solid var(--color-bg);
    min-height: 44px;
    transition: background 0.2s;
  }

  .btn-outline-dark:hover {
    background: rgba(20,20,20,0.08);
  }
</style>
