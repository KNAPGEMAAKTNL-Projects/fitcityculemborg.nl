---
interface Props {
  eyebrow?: string;
  title: string;
  centered?: boolean;
}

const { eyebrow, title, centered = false } = Astro.props;
---
<div class:list={['section-heading-wrap', { centered }]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2 class="section-title">{title}</h2>
</div>

<style>
  .section-heading-wrap {
    margin-bottom: 0.5rem;
  }

  .centered {
    text-align: center;
  }

  .centered .section-title::after {
    margin-left: auto;
    margin-right: auto;
  }

  .eyebrow {
    display: block;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: var(--color-text);
    text-transform: uppercase;
    line-height: 1.1;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: var(--color-primary);
    margin-top: 0.75rem;
  }
</style>
