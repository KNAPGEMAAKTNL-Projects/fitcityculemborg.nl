---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Pagina niet gevonden · Fitcity Culemborg"
  description="Deze pagina bestaat niet of is verplaatst."
  robots="noindex, nofollow"
>
  <Header />

  <section class="error-section">
    <div class="error-inner">
      <span class="error-code">404</span>
      <h1 class="error-heading">Pagina niet gevonden</h1>
      <p class="error-text">Deze pagina bestaat niet of is verplaatst. Geen zorgen, je kunt hieronder verder.</p>
      <div class="error-actions">
        <a href="/" class="btn-primary">NAAR DE HOMEPAGE</a>
        <a href="/contact/" class="btn-ghost">NEEM CONTACT OP</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .error-section {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    text-align: center;
  }

  .error-inner {
    max-width: 480px;
  }

  .error-code {
    font-family: var(--font-heading);
    font-size: 6rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }

  .error-heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .error-heading::after {
    display: none;
  }

  .error-text {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
</style>
