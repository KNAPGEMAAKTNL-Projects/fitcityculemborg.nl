---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import { pricingPlans, pricingExtras } from '../data/pricing';
---
<Layout
  title="Sportschool Culemborg · Fitness vanaf €20,50 · Fitcity Culemborg"
  description="De meest betaalbare sportschool van Culemborg. Fitness, ladies only en bokszaktraining. Vanaf €20,50/maand met gratis begeleiding. Je eerste proefles is altijd gratis."
>
  <Header />

  <!-- ============================================
       SECTION 1 — HERO (100svh, grid, center-right)
       ============================================ -->
  <section class="hero" id="hero">
    <!-- Video background -->
    <video class="hero-video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
      <source src="/fitcity-hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay" aria-hidden="true"></div>

    <!-- Visual Craft: CSS Blur Blob -->
    <div class="hero-blur-blob" aria-hidden="true"></div>

    <div class="hero-content hero-entrance">
      <!-- Glass pill reviews -->
      <a href="https://www.google.com/maps/search/Fitcity+Culemborg+Houtweg+8" target="_blank" rel="noopener" class="hero-reviews">
        <div class="hero-reviews-stars">
          {[1,2,3,4].map(() => (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#FFE303" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          ))}
          <!-- Partial star (70% fill for 4,7) -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="none">
            <defs>
              <linearGradient id="star-partial">
                <stop offset="70%" stop-color="#FFE303"/>
                <stop offset="70%" stop-color="#555"/>
              </linearGradient>
            </defs>
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#star-partial)"/>
          </svg>
        </div>
        <span class="hero-reviews-rating">4,7</span>
        <span class="hero-reviews-sep">|</span>
        <span class="hero-reviews-count">29 Google Reviews</span>
      </a>

      <h1 class="hero-title">Elke dag fitter</h1>
      <p class="hero-tagline">De meest betaalbare sportschool van Culemborg</p>

      <div class="hero-buttons">
        <a href="/signup/" class="btn-primary">WORD NU LID</a>
        <a href="#pricing" class="btn-ghost">BEKIJK PRIJZEN</a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <button class="hero-scroll" aria-label="Scroll naar beneden" id="hero-scroll-btn" type="button">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
    </button>
  </section>

  <!-- ============================================
       SECTION 2b — DIRECT ANSWER (SEO paragraph)
       ============================================ -->
  <section class="direct-answer">
    <div class="direct-answer-inner">
      <p>Fitcity Culemborg is de sportschool van Culemborg voor fitness, ladies only en bokszaktraining. Je traint op professionele apparatuur, op jouw tempo en met gratis begeleiding bij elk bezoek. Al vanaf €20,50 per maand ben je lid. Je eerste proefles is altijd gratis.</p>
    </div>
  </section>

  <!-- ============================================
       SECTION 4 — ONS AANBOD (asymmetric services grid)
       ============================================ -->
  <section class="services scroll-fade-up" data-scroll-reveal>
    <div class="services-container">
      <SectionHeading eyebrow="ONS AANBOD" title="WAT WIL JE TRAINEN?" />

      <nav class="services-grid stagger-container" aria-label="Onze diensten">
        <!-- Card 1: Fitness (spans 2 rows on desktop) -->
        <div class="service-card service-card--fitness hover-lift">
          <div class="service-card-image">
            <img src="/images/fitness.webp" alt="Fitness bij Fitcity Culemborg" loading="lazy" />
          </div>
          <div class="service-card-body">
            <h3 class="service-card-title">Fitness</h3>
            <p class="service-card-desc">Onbeperkt trainen op professionele apparatuur. Train wanneer het jou uitkomt, 7 dagen per week.</p>
            <a href="/fitness/" class="service-card-link">Meer info →</a>
          </div>
        </div>

        <!-- Card 2: Ladies Only -->
        <div class="service-card service-card--ladies hover-lift">
          <div class="service-card-image">
            <img src="/images/ladies-only.webp" alt="Ladies Only bij Fitcity Culemborg" loading="lazy" />
          </div>
          <div class="service-card-body">
            <h3 class="service-card-title">Ladies Only</h3>
            <p class="service-card-desc">Een eigen ruimte, alleen voor vrouwen. Dezelfde professionele apparatuur, eigen sfeer. Fitness op jouw voorwaarden.</p>
            <a href="/ladies-only/" class="service-card-link">Meer info →</a>
          </div>
        </div>

        <!-- Card 3: Kickboxing -->
        <div class="service-card service-card--kickboxing hover-lift">
          <div class="service-card-image">
            <img src="/images/bokszaktraining.webp" alt="Bokszaktraining bij Fitcity Culemborg" loading="lazy" />
          </div>
          <div class="service-card-body">
            <h3 class="service-card-title">Bokszaktraining</h3>
            <p class="service-card-desc">Bokszaktraining voor alle niveaus. Train op eigen tempo aan de bokszakken. Geen ervaring nodig, gewoon komen en doen.</p>
            <a href="/kickboxing/" class="service-card-link">Meer info →</a>
          </div>
        </div>
      </nav>
    </div>
  </section>

  <!-- ============================================
       SECTION 5 — DE VIBE (7fr/5fr, grain texture)
       ============================================ -->
  <section class="vibe scroll-fade-up" data-scroll-reveal>
    <!-- Visual Craft: SVG Grain Texture -->
    <svg class="vibe-grain" aria-hidden="true">
      <filter id="grain-vibe">
        <feTurbulence type="fractalNoise" baseFrequency="0.7" numOctaves="4" stitchTiles="stitch"/>
      </filter>
      <rect width="100%" height="100%" filter="url(#grain-vibe)"/>
    </svg>

    <div class="vibe-container">
      <SectionHeading eyebrow="WAAROM FITCITY" title="DE VIBE" />

      <div class="vibe-grid">
        <div class="vibe-text">
          <p class="vibe-lead">Je komt binnen, gooit je tas neer en je gaat trainen. Dát is Fitcity Culemborg.</p>
          <p>We zijn geen grote keten. We zijn een lokale sportschool waar de trainers je naam kennen, gewoon omdat het hier lekker trainen is. Er staat altijd iemand klaar om je te helpen.</p>
          <p>Zeven dagen per week open. Doordeweeks van 08:30 tot 22:00, in het weekend vanaf 09:00. Kom gerust een keer kijken, dan merk je het vanzelf.</p>

          <ul class="vibe-checklist">
            {[
              'Professionele apparatuur',
              'Ladies Only zone',
              'Bokszaktraining 2x per week',
              '7 dagen per week open',
            ].map(item => (
              <li>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="vibe-image">
          <video autoplay muted loop playsinline preload="auto" aria-hidden="true">
            <source src="/images/fitcity-sfeer.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 6 — PRIJZEN (3 cards + toggle)
       ============================================ -->
  <section class="pricing scroll-fade-up" data-scroll-reveal id="pricing">
    <div class="pricing-container">
      <SectionHeading eyebrow="LIDMAATSCHAP" title="PRIJZEN" centered />

      <p class="pricing-intro">Kies het abonnement dat bij je past.</p>

      <!-- Duration toggle -->
      <div class="pricing-toggle" role="tablist" aria-label="Abonnementsduur">
        {['jaar', 'halfjaar', 'flex'].map((plan, i) => (
          <button
            role="tab"
            class:list={['pricing-toggle-btn color-transition', { active: i === 0 }]}
            data-plan={plan}
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`pricing-${plan}`}
          >
            {plan.charAt(0).toUpperCase() + plan.slice(1)}
          </button>
        ))}
      </div>

      <!-- Pricing grids (one per duration) -->
      {Object.entries(pricingPlans).map(([key, plans], groupIndex) => (
        <div
          class="pricing-grid stagger-container"
          id={`pricing-${key}`}
          data-pricing-group={key}
          style={groupIndex > 0 ? 'display: none;' : ''}
        >
          {plans.map(plan => (
            <div class:list={['pricing-card', `pricing-card--${plan.accent}`, { 'pricing-card--unavailable': plan.unavailable }]}>
              {plan.badge && <span class="pricing-badge">{plan.badge}</span>}

              <div class="pricing-card-header">
                <h3 class="pricing-card-name">{plan.name}</h3>
                {plan.price ? (
                  <div class="pricing-card-price">
                    <span class="pricing-amount">{plan.price}</span>
                    <span class="pricing-period">{plan.period}</span>
                  </div>
                ) : null}
                {plan.duration && <p class="pricing-card-duration">{plan.duration}</p>}
              </div>

              {plan.unavailable ? (
                <p class="pricing-card-unavailable">{plan.unavailable}</p>
              ) : (
                <>
                  <ul class="pricing-features">
                    {plan.features.map(feature => (
                      <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                        {feature}
                      </li>
                    ))}
                  </ul>
                  <p class="pricing-card-footnote">€17,00 inschrijfkosten</p>
                  <a href={plan.href} class:list={['pricing-card-cta', `pricing-card-cta--${plan.accent}`]}>{plan.cta}</a>
                </>
              )}
            </div>
          ))}
        </div>
      ))}

      <!-- Extras -->
      <div class="pricing-extras">
        {pricingExtras.map(extra => (
          <div class="pricing-extra">
            <span class="pricing-extra-name">{extra.name}</span>
            <span class="pricing-extra-price">{extra.price}</span>
            <span class="pricing-extra-note">
              {extra.href ? <a href={extra.href}>{extra.note}</a> : extra.note}
            </span>
          </div>
        ))}
      </div>

      <p class="pricing-supporting">Liever eerst even kijken? Je eerste proefles is altijd gratis.</p>
    </div>
  </section>

  <!-- ============================================
       SECTION 7 — KICKBOXING GALLERY (asymmetric grid)
       ============================================ -->
  <section class="kickboxing scroll-fade-up" data-scroll-reveal>
    <div class="kickboxing-container">
      <SectionHeading eyebrow="BOKSZAKTRAINING" title="WORD STERKER" />

      <p class="kickboxing-body">Bokszaktraining voor alle niveaus. Train op eigen tempo aan de bokszakken en werk aan je kracht, conditie en techniek.</p>

      <p class="kickboxing-schedule">Di 19:00 · Do 19:00</p>

      <div class="kickboxing-gallery stagger-container">
        {[1,2,3,4,5].map((n) => (
          <div class:list={['kickboxing-item hover-image-overlay hover-image-zoom', { 'kickboxing-item--large': n === 1 }]}>
            <img src={`/images/kickboxen-${n}.webp`} alt={`Bokszaktraining bij Fitcity Culemborg`} loading="lazy" />
          </div>
        ))}
      </div>

      <a href="/kickboxing/" class="btn-ghost-yellow">BEKIJK BOKSZAKTRAINING PRIJZEN</a>
    </div>
  </section>

  <!-- ============================================
       SECTION 8 — GOOGLE REVIEWS STRIP
       ============================================ -->
  <section class="reviews-strip">
    <div class="reviews-strip-inner">
      <span class="reviews-strip-logo">FITCITY CULEMBORG</span>

      <div class="reviews-strip-stars">
        {[1,2,3,4].map(() => (
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#FFE303" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        ))}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="none">
          <defs><linearGradient id="star-partial-2"><stop offset="70%" stop-color="#FFE303"/><stop offset="70%" stop-color="#555"/></linearGradient></defs>
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#star-partial-2)"/>
        </svg>
      </div>

      <span class="reviews-strip-rating">4,7 uit 29 reviews</span>

      <span class="reviews-strip-sep">|</span>

      <a href="https://www.google.com/maps/search/Fitcity+Culemborg+Houtweg+8" class="reviews-strip-link" target="_blank" rel="noopener">Bekijk op Google</a>
    </div>
  </section>

  <!-- ============================================
       SECTION 9 — FAQ (details/summary accordion)
       ============================================ -->
  <section class="faq scroll-fade-up" data-scroll-reveal>
    <div class="faq-container">
      <SectionHeading eyebrow="FAQ" title="VEELGESTELDE VRAGEN" />

      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-question">
            Wat kost een abonnement bij Fitcity Culemborg?
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-answer">
            <p>De Smart Deal kost €24,50 per maand (12 maanden) voor onbeperkt fitness. De Ladies Only start bij €20,50 per maand. Wil je ook bokszaktraining? Dan is de Ultimate Fit Deal €37,50 per maand. Een dagpas kost €7,00. Eenmalig €17,00 inschrijfkosten bij alle abonnementen.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            Kan ik gratis komen uitproberen?
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-answer">
            <p>Ja, je eerste proefles is altijd gratis. Neem even contact op om een moment af te spreken dat jou uitkomt.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            Wat zijn de openingstijden?
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-answer">
            <p>Maandag t/m vrijdag: 08:30 tot 22:00. Zaterdag: 09:00 tot 16:00. Zondag: 09:30 tot 16:00. We zijn dus 7 dagen per week open.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            Kan ik mijn abonnement opzeggen?
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-answer">
            <p>Bij Flex abonnementen kun je opzeggen met 1 kalendermaand opzegtermijn. Bij vaste contracten geldt na afloop van de contractperiode ook 1 maand opzegtermijn. We houden je sowieso niet langer vast dan afgesproken.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            Is er altijd personeel aanwezig?
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-answer">
            <p>Ja, tijdens alle openingstijden is er personeel dat je gratis helpt en begeleidt. Je hoeft nooit zelf uit te zoeken hoe een apparaat werkt.</p>
          </div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">
            Wat is de Ladies Only zone?
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-answer">
            <p>Een aparte trainingsvloer beneden, alleen voor vrouwen. Volledig uitgerust met eigen apparatuur. Met een Ladies Only abonnement heb je ook gewoon toegang tot de rest van de gym.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ============================================
       SECTION 10 — CONTACT CTA (yellow full-bleed)
       ============================================ -->
  <CtaSection
    title="KLAAR OM TE BEGINNEN?"
    text="Je eerste proefles is altijd gratis. Kom gerust even langs, of word direct lid."
    primaryLabel="WORD NU LID"
    primaryHref="/signup/"
    secondaryLabel="PLAN PROEFTRAINING"
    secondaryHref="/contact/?onderwerp=proeftraining#contact-form"
  />

  <Footer />
  <MobileCTA />

  <!-- Restart hero video after view transition navigation -->
  <script>
    function restartHeroVideo() {
      const video = document.querySelector('.hero-video') as HTMLVideoElement | null;
      if (video) {
        video.play().catch(() => {});
      }
    }
    document.addEventListener('astro:page-load', restartHeroVideo);
  </script>

  <!-- Homepage interactive scripts — re-run after view transitions -->
  <script>
    function initHomepage() {
      // Scroll reveal fallback for Firefox
      if (!CSS.supports('animation-timeline', 'view()')) {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (!prefersReduced) {
          const elements = document.querySelectorAll('[data-scroll-reveal]');
          elements.forEach(el => el.classList.add('js-scroll-reveal'));
          const observer = new IntersectionObserver(
            entries => {
              entries.forEach(entry => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.1, rootMargin: '0px 0px -10% 0px' }
          );
          elements.forEach(el => observer.observe(el));
        }
      }

      // Hero scroll button
      const scrollBtn = document.getElementById('hero-scroll-btn');
      if (scrollBtn) {
        scrollBtn.addEventListener('click', () => {
          const hero = document.getElementById('hero');
          if (hero) {
            const nextSection = hero.nextElementSibling;
            if (nextSection) {
              nextSection.scrollIntoView({ behavior: 'smooth' });
            }
          }
        });
      }

      // Pricing toggle
      const toggleBtns = document.querySelectorAll('.pricing-toggle-btn');
      const grids = document.querySelectorAll('[data-pricing-group]');

      toggleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const plan = (btn as HTMLElement).dataset.plan;
          toggleBtns.forEach(b => {
            b.classList.remove('active');
            b.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('active');
          btn.setAttribute('aria-selected', 'true');
          grids.forEach(g => {
            (g as HTMLElement).style.display = (g as HTMLElement).dataset.pricingGroup === plan ? '' : 'none';
          });
        });
      });
    }

    initHomepage();
    document.addEventListener('astro:after-swap', initHomepage);
  </script>
</Layout>

<style>
  /* =========================================
     HERO
     ========================================= */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    overflow: hidden;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .hero-blur-blob {
    position: absolute;
    width: 300px;
    height: 300px;
    background: var(--color-primary);
    opacity: 0.04;
    filter: blur(100px);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .hero-blur-blob { width: 400px; height: 400px; }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 6rem 1.5rem 4rem;
    max-width: 620px;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding: 0 2rem;
    }
  }

  /* Glass pill */
  .hero-reviews {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 0.625rem 1.25rem;
    border-radius: 9999px;
    margin-bottom: 1.5rem;
  }

  .hero-reviews-stars { display: flex; gap: 2px; }
  .hero-reviews-stars svg { width: 16px; height: 16px; }
  .hero-reviews-rating { font-weight: 600; font-size: 0.95rem; color: var(--color-text); }
  .hero-reviews-sep { color: var(--color-separator); }
  .hero-reviews-count { font-size: 0.75rem; color: var(--color-text-muted); }

  .hero-reviews {
    text-decoration: none;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
  }

  @media (min-width: 768px) {
    .hero-reviews { gap: 0.75rem; padding: 0.625rem 1.25rem; }
    .hero-reviews-stars svg { width: 20px; height: 20px; }
    .hero-reviews-rating { font-size: 1.1rem; }
    .hero-reviews-count { font-size: 0.875rem; }
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1.0;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1.25rem;
  }

  .hero-reviews-sep {
    color: var(--color-separator);
    font-weight: 400;
  }

  .hero-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-buttons { flex-direction: row; justify-content: center; }
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    background: var(--color-primary);
    color: var(--color-bg);
    padding: 1rem 2.5rem;
    border: none;
    min-height: 44px;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.9; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    background: transparent;
    color: var(--color-text);
    padding: 1rem 2.5rem;
    border: 2px solid rgba(255,255,255,0.3);
    min-height: 44px;
    transition: border-color 0.2s;
  }

  .btn-ghost:hover { border-color: rgba(255,255,255,0.6); }

  .hero-scroll {
    position: absolute;
    bottom: 6rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
