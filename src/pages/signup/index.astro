---
import Layout from '../../layouts/Layout.astro';
import { pricingPlans, signupExtras } from '../../data/pricing';
---
<Layout
  title="Word Lid · Fitcity Culemborg"
  description="Schrijf je in bij Fitcity Culemborg. Kies je abonnement, vul je gegevens in en start met trainen. Vanaf €20,50 per maand."
>

  <!-- Minimal sales header: logo + step badges -->
  <header class="signup-header">
    <div class="signup-header-inner">
      <a href="/" class="signup-logo">
        <img src="/images/fitcity-logo.webp" alt="Fitcity Culemborg" height="36" />
      </a>
      <div class="signup-steps">
        <div class="step-badge active" data-step="1" role="button" tabindex="0">
          <span class="step-icon">1</span>
          <span class="step-label">Kies lidmaatschap</span>
        </div>
        <div class="step-badge" data-step="2" role="button" tabindex="0">
          <span class="step-icon">2</span>
          <span class="step-label">Jouw gegevens</span>
        </div>
        <div class="step-badge" data-step="3" role="button" tabindex="0">
          <span class="step-icon">3</span>
          <span class="step-label">Afronden</span>
        </div>
      </div>
    </div>
  </header>

  <main class="signup-main">
    <form id="signup-form" novalidate>

      <!-- Hidden fields for selected plan -->
      <input type="hidden" name="plan_slug" id="plan_slug" />
      <input type="hidden" name="plan_name" id="plan_name" />
      <input type="hidden" name="plan_price" id="plan_price" />
      <input type="hidden" name="plan_duration" id="plan_duration" />

      <!-- ===================== STEP 1: Kies Lidmaatschap ===================== -->
      <div class="form-step active" data-step="1">
        <div class="step-content step-content--wide">
          <h2 class="step-title">1. Kies Lidmaatschap</h2>

          <!-- Duration toggle with sliding pill -->
          <div class="duration-toggle-container">
            <div class="duration-toggle">
              <div class="slider-bg"></div>
              {['jaar', 'halfjaar', 'flex'].map((plan, i) => (
                <button
                  type="button"
                  class:list={['duration-btn', { active: i === 0 }]}
                  data-duration={plan}
                >
                  {plan === 'jaar' ? 'Jaar' : plan === 'halfjaar' ? 'Halfjaar' : 'Flex'}
                </button>
              ))}
            </div>
            <p class="duration-explanation" id="duration-explanation">Contract van 12 maanden. Daarna per maand opzegbaar</p>
          </div>

          <!-- Plan cards per duration -->
          {Object.entries(pricingPlans).map(([key, plans], groupIndex) => (
            <div
              class="signup-plans"
              data-plan-group={key}
              style={groupIndex > 0 ? 'display: none;' : ''}
            >
              {plans.map(plan => plan.unavailable ? (
                <div class="pricing-card pricing-card--unavailable">
                  <div class="pricing-card-header">
                    <h3 class="pricing-card-name">{plan.name}</h3>
                  </div>
                  <p class="pricing-card-unavailable-msg">{plan.unavailable}</p>
                </div>
              ) : (
                <div
                  class:list={['pricing-card', `pricing-card--${plan.accent}`, 'plan-selectable']}
                  data-slug={plan.slug}
                  data-name={plan.name}
                  data-price={plan.price}
                  data-duration={plan.duration}
                >
                  {plan.badge && <span class="pricing-badge">{plan.badge}</span>}

                  <div class="pricing-card-header">
                    <h3 class="pricing-card-name">{plan.name}</h3>
                    <div class="pricing-card-price">
                      <span class="pricing-amount">{plan.price}</span>
                      <span class="pricing-period">{plan.period}</span>
                    </div>
                    <p class="pricing-card-duration">{plan.duration}</p>
                  </div>

                  <ul class="pricing-features">
                    {plan.features.map(feature => (
                      <li>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                        {feature}
                      </li>
                    ))}
                  </ul>

                  <p class="pricing-card-footnote">&euro;17,00 inschrijfkosten</p>

                  <button type="button" class:list={['pricing-card-cta', `pricing-card-cta--${plan.accent}`]}>
                    {plan.cta}
                  </button>
                </div>
              ))}
            </div>
          ))}

          <!-- Extras: additional plans -->
          <h3 class="extras-heading">OVERIGE ABONNEMENTEN</h3>
          <div class="signup-extras">
            {signupExtras.map(extra => (
              <div
                class="signup-extra plan-selectable"
                data-slug={extra.slug}
                data-name={extra.name}
                data-price={extra.price}
                data-duration={extra.duration}
              >
                <div class="signup-extra-info">
                  <span class="signup-extra-name">{extra.name}</span>
                  <span class="signup-extra-note">{extra.note}</span>
                </div>
                <div class="signup-extra-price-wrap">
                  <span class="signup-extra-price">{extra.price}</span>
                  <span class="signup-extra-period">{extra.period}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- ===================== STEP 2: Jouw Gegevens ===================== -->
      <div class="form-step" data-step="2">
        <div class="step-content step-content--form">
          <!-- Order summary (collapsible, like old project) -->
          <div class="order-summary" id="order-summary">
            <button type="button" class="order-summary-header" id="summary-toggle">
              <div class="order-summary-title">
                <h3 id="float-name">Lidmaatschap</h3>
                <div class="order-summary-price-row">
                  <span class="order-summary-price" id="float-price">€—</span>
                  <span class="order-summary-period">/ maand</span>
                </div>
              </div>
              <svg class="order-summary-chevron" id="toggle-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
            </button>
            <div class="order-summary-details" id="summary-details">
              <div class="order-summary-section">
                <h4>Besteloverzicht</h4>
                <div class="order-summary-line order-summary-line--bold">
                  <span>Lidmaatschap kosten</span>
                  <span id="detail-price-head">€—</span>
                </div>
                <div class="order-summary-sub">
                  <div class="order-summary-line">
                    <span id="detail-name">—</span>
                    <span id="detail-price-row">€—</span>
                  </div>
                  <p id="detail-term-row">—</p>
                  <div class="order-summary-line">
                    <span>Startdatum:</span>
                    <span id="detail-start">—</span>
                  </div>
                  <div class="order-summary-line">
                    <span>Einddatum:</span>
                    <span id="detail-end">—</span>
                  </div>
                </div>
              </div>
              <div class="order-summary-section">
                <div class="order-summary-line order-summary-line--bold">
                  <span>BETAAL BIJ EERSTE BEZOEK</span>
                  <span class="order-summary-highlight" id="now-total">€17,00</span>
                </div>
                <div class="order-summary-sub">
                  <div class="order-summary-line">
                    <span>Inschrijfkosten</span>
                    <span>€17,00</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <h2 class="step-title step-title--left">2. Jouw gegevens</h2>

          <h3 class="form-section-title">Persoonlijke gegevens</h3>
          <div class="form-fields">
            <div class="form-field">
              <label for="first_name">Voornaam <span class="required">*</span></label>
              <input type="text" id="first_name" name="first_name" required autocomplete="given-name" />
              <p class="form-error" data-error="first_name">Dit veld is verplicht.</p>
            </div>

            <div class="form-field">
              <label for="last_name">Achternaam <span class="required">*</span></label>
              <input type="text" id="last_name" name="last_name" required autocomplete="family-name" />
              <p class="form-error" data-error="last_name">Dit veld is verplicht.</p>
            </div>

            <div class="form-field">
              <label for="phone">Telefoon <span class="required">*</span></label>
              <input type="tel" id="phone" name="phone" required autocomplete="tel" />
              <p class="form-error" data-error="phone">Dit veld is verplicht.</p>
            </div>

            <div class="form-field">
              <label for="email">E-mail <span class="required">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" />
              <p class="form-error" data-error="email">Vul een geldig e-mailadres in.</p>
            </div>

            <div class="form-field">
              <label for="email_confirm">Bevestig e-mail <span class="required">*</span></label>
              <input type="email" id="email_confirm" name="email_confirm" required autocomplete="off" />
              <p class="form-error" data-error="email_confirm">E-mailadressen komen niet overeen.</p>
            </div>

            <div class="form-field">
              <label for="date_of_birth">Geboortedatum <span class="required">*</span></label>
              <input type="date" id="date_of_birth" name="date_of_birth" required class="date-input" />
              <p class="form-error" data-error="date_of_birth">Vul een geldige datum in.</p>
            </div>
          </div>

          <h3 class="form-section-title">Adresgegevens</h3>
          <div class="form-fields">
            <div class="form-field">
              <label for="postcode">Postcode <span class="required">*</span></label>
              <input type="text" id="postcode" name="postcode" required placeholder="1234 AB" autocomplete="postal-code" />
              <p class="form-error" data-error="postcode">Ongeldige postcode (1234 AB).</p>
            </div>

            <div class="form-field">
              <label for="house_number">Huisnummer <span class="required">*</span></label>
              <input type="text" id="house_number" name="house_number" required inputmode="numeric" />
              <p class="form-error" data-error="house_number">Dit veld is verplicht.</p>
            </div>

            <div class="form-field">
              <label for="house_number_addition">Huisnummer toevoeging <span class="optional-hint">(optioneel)</span></label>
              <input type="text" id="house_number_addition" name="house_number_addition" placeholder="bijv. A, 3-hoog" />
            </div>

            <div class="form-field">
              <label for="street">Straatnaam <span class="required">*</span></label>
              <input type="text" id="street" name="street" required autocomplete="street-address" />
              <p class="form-error" data-error="street">Dit veld is verplicht.</p>
            </div>

            <div class="form-field">
              <label for="city">Stad <span class="required">*</span></label>
              <input type="text" id="city" name="city" required autocomplete="address-level2" />
              <p class="form-error" data-error="city">Dit veld is verplicht.</p>
            </div>
          </div>

          <h3 class="form-section-title">Communicatie</h3>
          <div class="form-fields">
            <label class="consent-label">
              <input type="checkbox" name="marketing_consent" id="marketing_consent" />
              <span>Ja, Fitcity Culemborg mag mij informatie sturen over openingstijden, updates en aanbiedingen.</span>
            </label>
          </div>

          <button type="button" class="btn-primary-full" id="btn-to-step3">NAAR AFRONDEN</button>
        </div>
      </div>

      <!-- ===================== STEP 3: Afronden ===================== -->
      <div class="form-step" data-step="3">
        <div class="step-content step-content--form">
          <h2 class="step-title step-title--left">3. Rond je inschrijving af</h2>
          <p class="step-subtitle">Je bent nog één stap verwijderd van je eerste workout!</p>

          <!-- Subscription + Payment summaries side by side -->
          <div class="summary-grid">
            <div class="summary-card">
              <h3>Jouw Abonnement</h3>
              <div class="summary-plan-row">
                <span class="summary-plan-name" id="summary-name">—</span>
                <span class="summary-plan-price" id="summary-price">—</span>
              </div>
              <div class="summary-details">
                <div class="summary-line"><span>Looptijd:</span><span id="summary-term">—</span></div>
                <div class="summary-line"><span>Startdatum:</span><span id="summary-start">—</span></div>
                <div class="summary-line"><span>Einddatum:</span><span id="summary-end">—</span></div>
              </div>
            </div>
            <div class="summary-card">
              <h3>Betaal bij eerste bezoek</h3>
              <div class="summary-details">
                <div class="summary-line"><span>Inschrijfkosten</span><span>€17,00</span></div>
                <div class="summary-line summary-line--total"><span>Totaal</span><span>€17,00</span></div>
              </div>
            </div>
          </div>

          <!-- Personal details review -->
          <div class="review-card">
            <div class="review-grid">
              <div class="review-col">
                <div class="review-col-header">
                  <span></span>
                  <button type="button" class="review-edit" data-drawer="personal">Wijzigen</button>
                </div>
                <p class="review-name" id="review-name">—</p>
                <p class="review-muted" id="review-dob">—</p>
                <p class="review-muted" id="review-email">—</p>
                <p class="review-muted" id="review-phone">—</p>
              </div>
              <div class="review-col review-col--border">
                <div class="review-col-header">
                  <span></span>
                  <button type="button" class="review-edit" data-drawer="address">Wijzigen</button>
                </div>
                <p class="review-bold" id="review-address">—</p>
                <p class="review-muted" id="review-zipcity">—</p>
              </div>
            </div>
          </div>

          <!-- IBAN section -->
          <div class="iban-section">
            <h3>IBAN</h3>
            <p class="iban-info">We gebruiken je IBAN om je lidmaatschap veilig automatisch te kunnen incasseren.</p>

            <div class="iban-card">
              <div class="form-field">
                <label for="account_holder">Naam rekeninghouder <span class="required">*</span></label>
                <input type="text" id="account_holder" name="account_holder" required />
                <p class="form-error" data-error="account_holder">Dit veld is verplicht.</p>
              </div>

              <div class="form-field">
                <label for="iban">Rekeningnummer (IBAN) <span class="required">*</span></label>
                <input type="text" id="iban" name="iban" required placeholder="NL00 BANK 0000 0000 00" inputmode="text" />
                <p class="form-error" data-error="iban">Ongeldig IBAN nummer.</p>
              </div>

              <label class="consent-label">
                <input type="checkbox" name="sepa_consent" id="sepa_consent" required />
                <span>Ik machtig hierbij automatische <a href="/voorwaarden/" target="_blank">SEPA-betalingen</a>.</span>
              </label>
              <p class="form-error" data-error="sepa_consent">Je moet akkoord gaan met de SEPA-machtiging</p>

              <label class="consent-label">
                <input type="checkbox" name="privacy_consent" id="privacy_consent" required />
                <input type="checkbox" name="terms_consent" id="terms_consent" required style="display:none;" />
                <span>Ik ga akkoord met de <a href="/voorwaarden/" target="_blank">algemene voorwaarden</a> en heb de <a href="/privacy/" target="_blank">privacyverklaring</a> gelezen <span class="required">*</span></span>
              </label>
              <p class="form-error" data-error="privacy_consent">Je moet akkoord gaan</p>
            </div>
          </div>

          <!-- Honeypot -->
          <div style="position: absolute; left: -9999px;" aria-hidden="true">
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <!-- Turnstile -->
          <div id="turnstile-signup"></div>

          <button type="submit" class="btn-primary-full" id="signup-submit">
            <span class="form-submit-text">INSCHRIJVING VOLTOOIEN</span>
            <span class="form-submit-loading" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"><animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/></path></svg>
            </span>
          </button>

          <div class="form-message form-success" id="form-success" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Je inschrijving is ontvangen! Je wordt doorgestuurd...
          </div>
          <div class="form-message form-error-msg" id="form-error" hidden>
            Er ging iets mis. Probeer het opnieuw of mail ons op info@fitcityculemborg.nl.
          </div>
        </div>
      </div>

    </form>

    <!-- Edit drawer (bottom sheet mobile, side panel desktop) -->
    <div id="edit-drawer" class="edit-drawer">
      <div class="drawer-header">
        <h3 id="drawer-title">Gegevens wijzigen</h3>
        <button type="button" id="close-drawer" class="drawer-close">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <div class="drawer-body">
        <div id="drawer-section-personal" class="drawer-fields">
          <div class="form-field">
            <label>Voornaam</label>
            <input type="text" id="drawer-first_name" />
          </div>
          <div class="form-field">
            <label>Achternaam</label>
            <input type="text" id="drawer-last_name" />
          </div>
          <div class="form-field">
            <label>Telefoon</label>
            <input type="tel" id="drawer-phone" />
          </div>
          <div class="form-field">
            <label>E-mail</label>
            <input type="email" id="drawer-email" />
          </div>
          <div class="form-field">
            <label>Geboortedatum</label>
            <input type="date" id="drawer-date_of_birth" class="date-input" />
          </div>
        </div>
        <div id="drawer-section-address" class="drawer-fields" style="display:none;">
          <div class="form-field">
            <label>Postcode</label>
            <input type="text" id="drawer-postcode" />
          </div>
          <div class="form-field">
            <label>Huisnummer</label>
            <input type="text" id="drawer-house_number" />
          </div>
          <div class="form-field">
            <label>Huisnummer toevoeging</label>
            <input type="text" id="drawer-house_number_addition" />
          </div>
          <div class="form-field">
            <label>Straatnaam</label>
            <input type="text" id="drawer-street" />
          </div>
          <div class="form-field">
            <label>Stad</label>
            <input type="text" id="drawer-city" />
          </div>
        </div>
      </div>
      <div class="drawer-footer">
        <button type="button" id="save-drawer" class="btn-primary-full">OPSLAAN EN SLUITEN</button>
      </div>
    </div>
    <div id="drawer-overlay" class="drawer-overlay"></div>
  </main>

</Layout>

<style>
  /* ===================== SALES HEADER ===================== */
  .signup-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .signup-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .signup-logo img {
    height: 36px;
    width: auto;
    display: block;
  }

  /* ===================== STEP BADGES (squared, like old project) ===================== */
  .signup-steps {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .step-badge {
    display: flex;
    align-items: center;
    height: 40px;
    padding: 0 1rem;
    background: rgba(255,255,255,0.05);
    border-radius: 4px;
    color: var(--color-text-muted);
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s;
    user-select: none;
  }

  .step-icon {
    font-size: 0.9rem;
  }

  .step-label {
    display: none;
    margin-left: 0.5rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (min-width: 640px) {
    .step-badge.active .step-label { display: inline-block; }
  }

  /* Active step: outlined with yellow number */
  .step-badge.active {
    border: 2px solid var(--color-primary);
    background: transparent;
  }

  .step-badge.active .step-icon {
    color: var(--color-primary);
  }

  /* Completed step: solid yellow with checkmark */
  .step-badge.completed {
    background: var(--color-primary);
    color: var(--color-bg);
    width: 40px;
    justify-content: center;
    padding: 0;
  }

  .step-badge.completed .step-icon { display: none; }
  .step-badge.completed .step-label { display: none; }

  .step-badge.completed::after {
    content: '✓';
    font-size: 1.2rem;
    font-weight: bold;
  }

  /* ===================== MAIN & CONTAINERS ===================== */
  .signup-main {
    min-height: calc(100vh - 65px);
    padding: 2rem 0 4rem;
  }

  #signup-form {
    position: relative;
  }

  .step-content {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .step-content--wide {
    max-width: 1200px;
  }

  .step-content--form {
    max-width: 800px;
  }

  @media (min-width: 768px) {
    .step-content { padding: 0 2rem; }
  }

  .form-step {
    display: none;
    animation: fadeIn 0.4s ease;
  }

  .form-step.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ===================== STEP TITLES ===================== */
  .step-title {
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .step-title--left {
    text-align: left;
    margin-bottom: 2rem;
  }

  .step-title::after { display: none; }

  .step-subtitle {
    color: var(--color-text-muted);
    margin-top: -1.5rem;
    margin-bottom: 2rem;
  }

  .form-section-title {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-top: 2rem;
    margin-bottom: 0.25rem;
  }

  .form-section-title:first-of-type {
    margin-top: 0;
  }

  /* ===================== DURATION TOGGLE (animated slider) ===================== */
  .duration-toggle-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }

  .duration-toggle {
    display: inline-flex;
    background: var(--color-surface);
    border-radius: 9999px;
