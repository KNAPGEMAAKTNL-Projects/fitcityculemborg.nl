<script>
  import { validateIBAN, formatIBAN, validatePostcode, normalizePostcode, validateEmail, validatePhone } from '../../utils/validation';
  import { TURNSTILE_SITE_KEY } from '../../config/turnstile';

  const STORAGE_KEY = 'fitcity-signup-draft';
  const PERSISTED_FIELDS = [
    'plan_slug', 'plan_name', 'plan_price', 'plan_duration',
    'first_name', 'last_name', 'email', 'phone', 'date_of_birth',
    'postcode', 'house_number', 'house_number_addition', 'street', 'city',
    'account_holder', 'iban'
  ];

  function initSignupPage() {
    const form = document.getElementById('signup-form') as HTMLFormElement;
    if (!form) return;

    const formSteps = document.querySelectorAll('.form-step') as NodeListOf<HTMLElement>;
    const stepBadges = document.querySelectorAll('.step-badge') as NodeListOf<HTMLElement>;
    const durationBtns = document.querySelectorAll('.duration-btn') as NodeListOf<HTMLButtonElement>;
    const planGroups = document.querySelectorAll('.signup-plans') as NodeListOf<HTMLElement>;
    const submitBtn = document.getElementById('signup-submit') as HTMLButtonElement;

    // Turnstile
    let signupTurnstileToken = '';
    function renderSignupTurnstile() {
      const container = document.getElementById('turnstile-signup');
      if (!container || typeof turnstile === 'undefined') return;
      container.innerHTML = '';
      turnstile.render(container, {
        sitekey: TURNSTILE_SITE_KEY,
        size: 'compact',
        theme: 'dark',
        callback: (token: string) => { signupTurnstileToken = token; },
        'expired-callback': () => { signupTurnstileToken = ''; },
      });
    }
    const signupTurnstileCheck = setInterval(() => {
      if (typeof turnstile !== 'undefined') { clearInterval(signupTurnstileCheck); renderSignupTurnstile(); }
    }, 200);
    const successMsg = document.getElementById('form-success') as HTMLElement;
    const errorMsg = document.getElementById('form-error') as HTMLElement;

    let currentStep = 1;

    // ===================== LOCALSTORAGE =====================
    function saveToStorage() {
      const data: Record<string, string> = {};
      for (const name of PERSISTED_FIELDS) {
        const el = form.elements.namedItem(name) as HTMLInputElement;
        if (el) data[name] = el.value;
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    }

    function restoreFromStorage(): boolean {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      try {
        const data = JSON.parse(raw) as Record<string, string>;
        let hasData = false;
        for (const name of PERSISTED_FIELDS) {
          const el = form.elements.namedItem(name) as HTMLInputElement;
          if (el && data[name]) { el.value = data[name]; hasData = true; }
        }
        return hasData;
      } catch { return false; }
    }

    function clearStorage() {
      localStorage.removeItem(STORAGE_KEY);
    }

    // Auto-save on any input change
    form.addEventListener('input', saveToStorage);

    // ===================== STEP NAVIGATION =====================
    function goToStep(step: number) {
      currentStep = step;
      formSteps.forEach(s => {
        s.classList.toggle('active', parseInt(s.dataset.step || '0') === step);
      });
      stepBadges.forEach(badge => {
        const n = parseInt(badge.dataset.step || '0');
        badge.classList.remove('active', 'completed');
        if (n === step) badge.classList.add('active');
        else if (n < step) badge.classList.add('completed');
      });
      if (step === 1) requestAnimationFrame(updateSlider);
      if (step >= 2) updateOrderSummary();
      if (step === 3) updateFinalReview();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    stepBadges.forEach(badge => {
      badge.addEventListener('click', () => {
        const target = parseInt(badge.dataset.step || '1');
        if (target < currentStep) goToStep(target);
      });
    });

    document.getElementById('btn-to-step3')?.addEventListener('click', () => {
      if (validateStep(2)) goToStep(3);
    });

    // ===================== DURATION TOGGLE =====================
    function updateSlider() {
      const slider = document.querySelector('.slider-bg') as HTMLElement;
      const activeBtn = document.querySelector('.duration-btn.active') as HTMLElement;
      if (slider && activeBtn) {
        slider.style.width = `${activeBtn.offsetWidth}px`;
        slider.style.transform = `translateX(${activeBtn.offsetLeft}px)`;
      }
    }

    requestAnimationFrame(updateSlider);

    const durationExplanations: Record<string, string> = {
      'jaar': 'Contract van 12 maanden. Daarna per maand opzegbaar',
      'halfjaar': 'Contract van 6 maanden. Daarna per maand opzegbaar',
      'flex': 'Op elk moment opzegbaar met een opzegtermijn van één maand',
    };

    durationBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        durationBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        updateSlider();
        const planKey = btn.dataset.duration;
        planGroups.forEach(group => {
          group.style.display = group.dataset.planGroup === planKey ? 'grid' : 'none';
        });
        const explanationEl = document.getElementById('duration-explanation');
        if (explanationEl && planKey) explanationEl.textContent = durationExplanations[planKey] || '';
      });
    });

    // ===================== PLAN SELECTION =====================
    function selectPlan(el: HTMLElement) {
      document.querySelectorAll('.plan-selectable').forEach(c => c.classList.remove('selected'));
      el.classList.add('selected');
      (document.getElementById('plan_slug') as HTMLInputElement).value = el.dataset.slug || '';
      (document.getElementById('plan_name') as HTMLInputElement).value = el.dataset.name || '';
      (document.getElementById('plan_price') as HTMLInputElement).value = el.dataset.price || '';
      (document.getElementById('plan_duration') as HTMLInputElement).value = el.dataset.duration || '';
      saveToStorage();
      goToStep(2);
    }

    document.querySelectorAll('.plan-selectable').forEach(card => {
      const ctaBtn = card.querySelector('.pricing-card-cta');
      if (ctaBtn) ctaBtn.addEventListener('click', (e) => { e.stopPropagation(); selectPlan(card as HTMLElement); });
      card.addEventListener('click', () => selectPlan(card as HTMLElement));
    });

    // ===================== URL PRE-SELECTION =====================
    function handlePreselection() {
      const params = new URLSearchParams(window.location.search);
      const planSlug = params.get('plan');
      if (!planSlug) return false;

      const card = document.querySelector(`.plan-selectable[data-slug="${planSlug}"]`) as HTMLElement | null;
      if (!card) return false;

      const group = card.closest('.signup-plans') as HTMLElement | null;
      if (group) {
        const groupKey = group.dataset.planGroup;
        durationBtns.forEach(btn => {
          btn.classList.remove('active');
          if (btn.dataset.duration === groupKey) btn.classList.add('active');
        });
        planGroups.forEach(g => { g.style.display = g.dataset.planGroup === groupKey ? 'grid' : 'none'; });
        requestAnimationFrame(updateSlider);
      }

      document.querySelectorAll('.plan-selectable').forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      (document.getElementById('plan_slug') as HTMLInputElement).value = card.dataset.slug || '';
      (document.getElementById('plan_name') as HTMLInputElement).value = card.dataset.name || '';
      (document.getElementById('plan_price') as HTMLInputElement).value = card.dataset.price || '';
      (document.getElementById('plan_duration') as HTMLInputElement).value = card.dataset.duration || '';
      saveToStorage();
      goToStep(2);
      return true;
    }

    // ===================== ORDER SUMMARY =====================
    document.getElementById('summary-toggle')?.addEventListener('click', () => {
      document.getElementById('summary-details')?.classList.toggle('open');
      document.getElementById('toggle-icon')?.classList.toggle('open');
    });

    function calcEndDate(duration: string): Date {
      const end = new Date();
      if (duration.includes('12')) end.setFullYear(end.getFullYear() + 1);
      else if (duration.includes('6')) end.setMonth(end.getMonth() + 6);
      else if (duration.includes('3')) end.setMonth(end.getMonth() + 3);
      else end.setMonth(end.getMonth() + 1);
      return end;
    }

    function updateOrderSummary() {
      const name = (document.getElementById('plan_name') as HTMLInputElement).value;
      const price = (document.getElementById('plan_price') as HTMLInputElement).value;
      const duration = (document.getElementById('plan_duration') as HTMLInputElement).value;
      const start = new Date();
      const end = calcEndDate(duration);

      const set = (id: string, val: string) => { const el = document.getElementById(id); if (el) el.textContent = val; };
      set('float-name', name);
      set('float-price', price);
      set('detail-price-head', price);
      set('detail-name', name);
      set('detail-price-row', price);
      set('detail-term-row', duration);
      set('detail-start', start.toLocaleDateString('nl-NL'));
      set('detail-end', end.toLocaleDateString('nl-NL'));
    }

    // ===================== FINAL REVIEW =====================
    function updateFinalReview() {
      const get = (id: string) => (document.getElementById(id) as HTMLInputElement)?.value || '—';
      const set = (id: string, val: string) => { const el = document.getElementById(id); if (el) el.textContent = val; };

      const name = get('plan_name');
      const price = get('plan_price');
      const duration = get('plan_duration');
      const end = calcEndDate(duration);

      set('summary-name', name);
      set('summary-price', `${price} / maand`);
      set('summary-term', duration);
      set('summary-start', new Date().toLocaleDateString('nl-NL'));
      set('summary-end', end.toLocaleDateString('nl-NL'));
      set('review-name', `${get('first_name')} ${get('last_name')}`);
      set('review-email', get('email'));
      set('review-phone', get('phone'));

      const dob = get('date_of_birth');
      if (dob !== '—') { const [y, m, d] = dob.split('-'); set('review-dob', `${d}-${m}-${y}`); }

      const additionEl = document.getElementById('house_number_addition') as HTMLInputElement | null;
      const addition = additionEl?.value || '';
      set('review-address', `${get('street')} ${get('house_number')}${addition}`);
      set('review-zipcity', `${get('postcode')} ${get('city')}`);
    }

    // ===================== VALIDATION =====================
    function setFieldError(name: string, hasError: boolean) {
      const field = form.querySelector(`[name="${name}"]`) as HTMLElement | null;
      if (!field) return;
      const wrapper = field.closest('.form-field');
      if (wrapper) wrapper.classList.toggle('has-error', hasError);
    }

    function validateStep(step: number): boolean {
      form.querySelectorAll('.has-error').forEach(el => el.classList.remove('has-error'));
      let valid = true;

      if (step === 1 && !(document.getElementById('plan_slug') as HTMLInputElement).value) valid = false;

      if (step === 2) {
        const fields: { name: string; validate?: (v: string) => boolean }[] = [
          { name: 'first_name' },
          { name: 'last_name' },
          { name: 'phone', validate: validatePhone },
          { name: 'email', validate: validateEmail },
          { name: 'date_of_birth' },
          { name: 'postcode', validate: validatePostcode },
          { name: 'house_number' },
          { name: 'street' },
          { name: 'city' },
        ];
        for (const field of fields) {
          const el = form.elements.namedItem(field.name) as HTMLInputElement;
          if (!el) continue;
          const val = el.value.trim();
          let fieldValid = val !== '';
          if (fieldValid && field.validate) fieldValid = field.validate(val);
          if (!fieldValid) { setFieldError(field.name, true); valid = false; }
        }

        // Email confirm validation
        const emailEl = form.elements.namedItem('email') as HTMLInputElement;
        const confirmEl = form.elements.namedItem('email_confirm') as HTMLInputElement;
        if (emailEl && confirmEl) {
          if (!confirmEl.value.trim() || confirmEl.value.trim().toLowerCase() !== emailEl.value.trim().toLowerCase()) {
            setFieldError('email_confirm', true);
            valid = false;
          }
        }
      }

      if (step === 3) {
        if (!(form.elements.namedItem('account_holder') as HTMLInputElement).value.trim()) { setFieldError('account_holder', true); valid = false; }
        if (!validateIBAN((form.elements.namedItem('iban') as HTMLInputElement).value)) { setFieldError('iban', true); valid = false; }
        if (!(form.elements.namedItem('sepa_consent') as HTMLInputElement).checked) { setFieldError('sepa_consent', true); valid = false; }
        if (!(form.elements.namedItem('privacy_consent') as HTMLInputElement).checked) { setFieldError('privacy_consent', true); valid = false; }
      }

      return valid;
    }

    // Blur + input validation
    const blurValidators: Record<string, (el: HTMLInputElement) => boolean> = {
      first_name: (el) => el.value.trim() !== '',
      last_name: (el) => el.value.trim() !== '',
      email: (el) => el.value.trim() !== '' && validateEmail(el.value),
      phone: (el) => el.value.trim() !== '' && validatePhone(el.value),
      date_of_birth: (el) => el.value !== '',
      street: (el) => el.value.trim() !== '',
      house_number: (el) => el.value.trim() !== '',
      postcode: (el) => el.value.trim() !== '' && validatePostcode(el.value),
      city: (el) => el.value.trim() !== '',
      account_holder: (el) => el.value.trim() !== '',
      iban: (el) => el.value.trim() !== '' && validateIBAN(el.value),
    };

    Object.entries(blurValidators).forEach(([name, validator]) => {
      const el = form.elements.namedItem(name) as HTMLInputElement | null;
      if (!el) return;
      el.addEventListener('blur', () => { if (el.value.trim() !== '') setFieldError(name, !validator(el)); });
      el.addEventListener('input', () => setFieldError(name, false));
    });

    // Email confirm — validate on blur only, clear error on input
    const emailConfirmEl = form.elements.namedItem('email_confirm') as HTMLInputElement | null;
    const emailMainEl = form.elements.namedItem('email') as HTMLInputElement | null;
    emailConfirmEl?.addEventListener('blur', () => {
      if (emailConfirmEl.value.trim() !== '') {
        const match = emailConfirmEl.value.trim().toLowerCase() === emailMainEl?.value.trim().toLowerCase();
        setFieldError('email_confirm', !match);
      }
    });
    emailConfirmEl?.addEventListener('input', () => setFieldError('email_confirm', false));
    // If user changes the main email after confirming, clear confirm error
    emailMainEl?.addEventListener('input', () => setFieldError('email_confirm', false));

    // ===================== AUTO-FORMAT =====================
    const postcodeInput = document.getElementById('postcode') as HTMLInputElement | null;
    postcodeInput?.addEventListener('input', () => {
      const raw = postcodeInput.value.replace(/\s+/g, '').toUpperCase();
      if (raw.length >= 5) postcodeInput.value = normalizePostcode(raw);
    });

    const ibanInput = document.getElementById('iban') as HTMLInputElement | null;
    ibanInput?.addEventListener('input', () => {
      const cursorPos = ibanInput.selectionStart || 0;
      const oldLen = ibanInput.value.length;
      ibanInput.value = formatIBAN(ibanInput.value);
      const newLen = ibanInput.value.length;
      let newCursor = cursorPos + (newLen - oldLen);
      // Skip cursor past auto-inserted spaces
      if (ibanInput.value[newCursor - 1] === ' ' && newLen > oldLen) {
        newCursor = Math.min(newCursor, ibanInput.value.length);
      }
      ibanInput.setSelectionRange(newCursor, newCursor);
    });

    // ===================== PDOK POSTCODE AUTO-FILL =====================
    let pdokTimeout: ReturnType<typeof setTimeout> | null = null;

    async function lookupAddress(postcode: string, houseNumber: string, streetTarget: HTMLInputElement, cityTarget: HTMLInputElement) {
      const pc = postcode.replace(/\s+/g, '').toUpperCase();
      if (!/^\d{4}[A-Z]{2}$/.test(pc) || !houseNumber.trim()) return;

      try {
        const url = `https://api.pdok.nl/bzk/locatieserver/search/v3_1/free?q=postcode:${pc}+and+huisnummer:${encodeURIComponent(houseNumber.trim())}&rows=1&fl=straatnaam,woonplaatsnaam`;
        const res = await fetch(url);
        if (!res.ok) return;
        const json = await res.json();
        if (json.response?.numFound > 0) {
          const doc = json.response.docs[0];
          if (doc.straatnaam) streetTarget.value = doc.straatnaam;
          if (doc.woonplaatsnaam) cityTarget.value = doc.woonplaatsnaam;
          saveToStorage();
        }
      } catch {
        // Silent fallback — user fills fields manually
      }
    }

    function setupPdokLookup(postcodeId: string, houseNumberId: string, streetId: string, cityId: string) {
      const pcEl = document.getElementById(postcodeId) as HTMLInputElement | null;
      const hnEl = document.getElementById(houseNumberId) as HTMLInputElement | null;
      const stEl = document.getElementById(streetId) as HTMLInputElement | null;
      const ctEl = document.getElementById(cityId) as HTMLInputElement | null;
      if (!pcEl || !hnEl || !stEl || !ctEl) return;

      const trigger = () => {
        if (pdokTimeout) clearTimeout(pdokTimeout);
        pdokTimeout = setTimeout(() => lookupAddress(pcEl.value, hnEl.value, stEl, ctEl), 500);
      };

      pcEl.addEventListener('input', trigger);
      hnEl.addEventListener('input', trigger);
    }

    // Main form auto-fill
    setupPdokLookup('postcode', 'house_number', 'street', 'city');
    // Drawer auto-fill
    setupPdokLookup('drawer-postcode', 'drawer-house_number', 'drawer-street', 'drawer-city');

    // ===================== EDIT DRAWER =====================
    const drawer = document.getElementById('edit-drawer');
    const drawerOverlay = document.getElementById('drawer-overlay');
    const drawerFieldMap: Record<string, Record<string, string>> = {
      personal: {
        'drawer-first_name': 'first_name',
        'drawer-last_name': 'last_name',
        'drawer-phone': 'phone',
        'drawer-email': 'email',
        'drawer-date_of_birth': 'date_of_birth',
      },
      address: {
        'drawer-postcode': 'postcode',
        'drawer-house_number': 'house_number',
        'drawer-house_number_addition': 'house_number_addition',
        'drawer-street': 'street',
        'drawer-city': 'city',
      },
    };
    let activeDrawerSection = 'personal';

    function openDrawer(section: string) {
      activeDrawerSection = section;
      const sectionPersonal = document.getElementById('drawer-section-personal');
      const sectionAddress = document.getElementById('drawer-section-address');
      const drawerTitle = document.getElementById('drawer-title');
      if (sectionPersonal) sectionPersonal.style.display = section === 'personal' ? 'flex' : 'none';
      if (sectionAddress) sectionAddress.style.display = section === 'address' ? 'flex' : 'none';
      if (drawerTitle) drawerTitle.textContent = section === 'personal' ? 'Persoonlijke gegevens wijzigen' : 'Adresgegevens wijzigen';

      for (const [drawerId, formName] of Object.entries(drawerFieldMap[section])) {
        const formEl = form.elements.namedItem(formName) as HTMLInputElement;
        const drawerEl = document.getElementById(drawerId) as HTMLInputElement;
        if (formEl && drawerEl) drawerEl.value = formEl.value;
      }
      drawer?.classList.add('open');
      drawerOverlay?.classList.add('open');
    }

    function closeDrawer() {
      drawer?.classList.remove('open');
      drawerOverlay?.classList.remove('open');
    }

    function saveDrawer() {
      for (const [drawerId, formName] of Object.entries(drawerFieldMap[activeDrawerSection])) {
        const formEl = form.elements.namedItem(formName) as HTMLInputElement;
        const drawerEl = document.getElementById(drawerId) as HTMLInputElement;
        if (formEl && drawerEl) formEl.value = drawerEl.value;
      }
      saveToStorage();
      updateFinalReview();
      closeDrawer();
    }

    document.querySelectorAll('[data-drawer]').forEach(btn => {
      btn.addEventListener('click', () => openDrawer((btn as HTMLElement).dataset.drawer || 'personal'));
    });
    document.getElementById('close-drawer')?.addEventListener('click', closeDrawer);
    document.getElementById('save-drawer')?.addEventListener('click', saveDrawer);
    drawerOverlay?.addEventListener('click', closeDrawer);

    // ===================== FORM SUBMISSION =====================
    const privacyConsent = document.getElementById('privacy_consent') as HTMLInputElement;
    const termsConsent = document.getElementById('terms_consent') as HTMLInputElement;
    if (privacyConsent && termsConsent) {
      privacyConsent.addEventListener('change', () => { termsConsent.checked = privacyConsent.checked; });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      successMsg?.setAttribute('hidden', '');
      errorMsg?.setAttribute('hidden', '');
      if (!validateStep(3)) return;

      // Check Turnstile token
      if (!signupTurnstileToken) {
        errorMsg?.removeAttribute('hidden');
        return;
      }

      submitBtn.classList.add('is-loading');
      try {
        const data: Record<string, unknown> = {};
        for (const name of PERSISTED_FIELDS) {
          const el = form.elements.namedItem(name) as HTMLInputElement;
          if (el) data[name] = el.value;
        }
        data.honeypot = (form.elements.namedItem('website') as HTMLInputElement)?.value || '';
        data.privacy_consent = (form.elements.namedItem('privacy_consent') as HTMLInputElement).checked;
        data.terms_consent = (form.elements.namedItem('terms_consent') as HTMLInputElement).checked;
        data.sepa_consent = (form.elements.namedItem('sepa_consent') as HTMLInputElement).checked;
        data.marketing_consent = (form.elements.namedItem('marketing_consent') as HTMLInputElement)?.checked ?? false;
        data.cf_turnstile_response = signupTurnstileToken;

        const response = await fetch('/api/signup/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          clearStorage();
          successMsg?.removeAttribute('hidden');
          setTimeout(() => { window.location.href = '/signup/success/'; }, 1500);
        } else {
          const result = await response.json().catch(() => null);
          if (result?.field) setFieldError(result.field, true);
          if (result?.error) {
            const errorEl = document.getElementById('form-error');
            if (errorEl) errorEl.textContent = result.error;
          }
          errorMsg?.removeAttribute('hidden');
        }
      } catch {
        errorMsg?.removeAttribute('hidden');
      } finally {
        submitBtn.classList.remove('is-loading');
      }
    });

    // ===================== INIT: restore + preselect =====================
    // URL pre-selection takes priority over localStorage
    if (!handlePreselection()) {
      // Restore from localStorage
      const restored = restoreFromStorage();
      if (restored) {
        const planSlug = (document.getElementById('plan_slug') as HTMLInputElement).value;
        if (planSlug) {
          // Highlight the saved plan card and activate correct duration tab
          const card = document.querySelector(`.plan-selectable[data-slug="${planSlug}"]`) as HTMLElement | null;
          if (card) {
            card.classList.add('selected');
            const group = card.closest('.signup-plans') as HTMLElement | null;
            if (group) {
              const groupKey = group.dataset.planGroup;
              durationBtns.forEach(btn => {
                btn.classList.remove('active');
                if (btn.dataset.duration === groupKey) btn.classList.add('active');
              });
              planGroups.forEach(g => { g.style.display = g.dataset.planGroup === groupKey ? 'grid' : 'none'; });
              requestAnimationFrame(updateSlider);
            }
          }
          // Go to step 2 since plan is already selected
          goToStep(2);
        }
      }
    }

    // Resize handler for slider
    window.addEventListener('resize', () => requestAnimationFrame(updateSlider));
  }

  // Run on every page load (including ViewTransition navigations)
  document.addEventListener('astro:page-load', initSignupPage);
</script>
